{%- comment -%}
  Albora — Vitrine de produtos ("Mais vendidos").
  Cabeçalho com título + botão (CTA) e carrossel Swiper de cards.
  O card vem do snippet reutilizável `res-cards.liquid` (CSS em base.css).
  Swiper carregado globalmente via snippet `swiper-cdn` no theme.liquid.
  Ver CLAUDE.md → "Regra de personalização de textos e botões".
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign uid = section.id
  assign products = s.collection.products
-%}

<style>
  #Albora-FeaturedProducts-{{ uid }} {
    --fp-title-color: {{ s.title_color }};
    --fp-btn-color: {{ s.button_color }};
    --fp-btn-bg: {{ s.button_background }};

    position: relative;
    width: 100%;
    box-sizing: border-box;
    font-family: 'Montserrat', var(--font-body-family, sans-serif);
    padding-top: {{ s.padding_top }}px;
    padding-bottom: {{ s.padding_bottom }}px;
    background: {{ s.section_background }};
  }
  #Albora-FeaturedProducts-{{ uid }} .albora-fp__inner {
    box-sizing: border-box;
    max-width: {{ s.container_width }}px;
    margin: 0 auto;
    padding-inline: 24px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  #Albora-FeaturedProducts-{{ uid }} .albora-fp__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
  }
  #Albora-FeaturedProducts-{{ uid }} .albora-fp__title {
    margin: 0;
    color: var(--fp-title-color);
    text-transform: uppercase;
    line-height: normal;
    font-size: {{ s.title_font_size_desktop }}px;
    font-weight: {{ s.title_font_weight }};
  }
  #Albora-FeaturedProducts-{{ uid }} .albora-fp__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    flex-shrink: 0;
    padding: 0 20px;
    border: none;
    border-radius: 54px;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    background: var(--fp-btn-bg);
    color: var(--fp-btn-color);
    font-family: inherit;
    transition: opacity 0.2s ease;
    height: {{ s.button_height_desktop }}px;
    font-size: {{ s.button_font_size_desktop }}px;
    font-weight: {{ s.button_font_weight }};
  }
  #Albora-FeaturedProducts-{{ uid }} .albora-fp__button:hover { opacity: 0.9; }

  /* Carrossel: slides com altura igual para os preços alinharem na base. */
  #Albora-FeaturedProducts-{{ uid }} .albora-fp__swiper {
    width: 100%;
  }
  #Albora-FeaturedProducts-{{ uid }} .albora-fp__swiper .swiper-slide {
    height: auto;
    display: flex;
  }
  #Albora-FeaturedProducts-{{ uid }} .albora-fp__swiper .swiper-slide > .res-card {
    width: 100%;
  }
  /* Sem JS (ou antes do init) o wrapper já se comporta como grid. */
  #Albora-FeaturedProducts-{{ uid }} .albora-fp__swiper:not(.swiper-initialized) .swiper-wrapper {
    display: grid;
    grid-template-columns: repeat({{ s.columns_desktop }}, minmax(0, 1fr));
    gap: 32px;
  }
  #Albora-FeaturedProducts-{{ uid }} .swiper-button-next,
  #Albora-FeaturedProducts-{{ uid }} .swiper-button-prev {
    color: {{ s.controls_color }};
  }
  #Albora-FeaturedProducts-{{ uid }} .swiper-pagination-bullet-active {
    background: {{ s.controls_color }};
  }
  {%- if s.show_pagination %}
    #Albora-FeaturedProducts-{{ uid }} .albora-fp__swiper { padding-bottom: 36px; }
  {%- endif %}

  /* Tipografia do card vinda dos settings (escopada nesta instância). */
  #Albora-FeaturedProducts-{{ uid }} .res-card {
    --res-card-title-size: {{ s.card_title_font_size_desktop }}px;
    --res-card-title-weight: {{ s.card_title_font_weight }};
    --res-card-title-color: {{ s.card_title_color }};
    --res-card-description-size: {{ s.card_description_font_size_desktop }}px;
    --res-card-description-weight: {{ s.card_description_font_weight }};
    --res-card-description-color: {{ s.card_description_color }};
    --res-card-price-size: {{ s.card_price_font_size_desktop }}px;
    --res-card-price-weight: {{ s.card_price_font_weight }};
    --res-card-price-color: {{ s.card_price_color }};
    --res-card-price-compare-size: {{ s.card_price_compare_font_size_desktop }}px;
    --res-card-price-compare-weight: {{ s.card_price_compare_font_weight }};
    --res-card-price-compare-color: {{ s.card_price_compare_color }};
  }

  @media screen and (max-width: 989px) {
    #Albora-FeaturedProducts-{{ uid }} .albora-fp__swiper:not(.swiper-initialized) .swiper-wrapper {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 24px;
    }
  }
  @media screen and (max-width: 749px) {
    #Albora-FeaturedProducts-{{ uid }} .albora-fp__inner {
      padding-inline: 16px;
      gap: 24px;
    }
    #Albora-FeaturedProducts-{{ uid }} .albora-fp__title {
      font-size: {{ s.title_font_size_mobile }}px;
    }
    #Albora-FeaturedProducts-{{ uid }} .albora-fp__button {
      height: {{ s.button_height_mobile }}px;
      font-size: {{ s.button_font_size_mobile }}px;
      padding: 0 16px;
    }
    #Albora-FeaturedProducts-{{ uid }} .albora-fp__swiper:not(.swiper-initialized) .swiper-wrapper {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }
    #Albora-FeaturedProducts-{{ uid }} .res-card {
      --res-card-title-size: {{ s.card_title_font_size_mobile }}px;
      --res-card-description-size: {{ s.card_description_font_size_mobile }}px;
      --res-card-price-size: {{ s.card_price_font_size_mobile }}px;
      --res-card-price-compare-size: {{ s.card_price_compare_font_size_mobile }}px;
      --res-card-gap: 16px;
    }
  }
</style>

<section id="Albora-FeaturedProducts-{{ uid }}" class="albora-fp">
  <div class="albora-fp__inner">
    {%- if s.title != blank or s.button_label != blank -%}
      <div class="albora-fp__header">
        {%- if s.title != blank -%}
          <h2 class="albora-fp__title">{{ s.title }}</h2>
        {%- endif -%}
        {%- if s.button_label != blank -%}
          <a
            href="{{ s.button_link | default: s.collection.url | default: '#' }}"
            class="albora-fp__button"
            {% if s.button_link == blank and s.collection == blank %}
              role="link"
              aria-disabled="true"
            {% endif %}
          >
            {{ s.button_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div
      class="swiper albora-fp__swiper"
      data-albora-fp
      data-slides-desktop="{{ s.columns_desktop }}"
      data-slides-tablet="{{ s.slides_per_view_tablet }}"
      data-slides-mobile="{{ s.slides_per_view_mobile }}"
      data-navigation="{{ s.show_navigation }}"
      data-pagination="{{ s.show_pagination }}"
      data-loop="{{ s.loop }}"
    >
      <div class="swiper-wrapper">
        {%- if products.size > 0 -%}
          {%- for product in products limit: s.products_to_show -%}
            {%- if forloop.index <= s.columns_desktop -%}
              {%- assign card_image_loading = 'eager' -%}
            {%- else -%}
              {%- assign card_image_loading = 'lazy' -%}
            {%- endif -%}
            <div class="swiper-slide">
              {% render 'res-cards',
                product: product,
                show_description: s.show_description,
                show_wishlist: s.show_wishlist,
                description_words: s.description_words,
                image_loading: card_image_loading
              %}
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..s.products_to_show) -%}
            <div class="swiper-slide">
              {% render 'res-cards', show_description: s.show_description, show_wishlist: s.show_wishlist %}
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      {%- if s.show_pagination -%}
        <div class="swiper-pagination"></div>
      {%- endif -%}
      {%- if s.show_navigation -%}
        <div class="swiper-button-prev"></div>
        <div class="swiper-button-next"></div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function () {
    function initVitrine(el) {
      if (!el || el.dataset.inited === 'true') return true;
      if (typeof Swiper === 'undefined') return false;
      el.dataset.inited = 'true';

      var config = {
        // Centraliza quando há menos produtos do que cabem na viewport,
        // evitando cards colados na borda esquerda.
        centerInsufficientSlides: true,
        watchOverflow: true,
        loop: el.dataset.loop === 'true',
        slidesPerView: parseFloat(el.dataset.slidesMobile) || 1.7,
        spaceBetween: 16,
        breakpoints: {
          750: {
            slidesPerView: parseFloat(el.dataset.slidesTablet) || 2,
            spaceBetween: 24,
          },
          990: {
            slidesPerView: parseInt(el.dataset.slidesDesktop, 10) || 4,
            spaceBetween: 32,
          },
        },
      };

      if (el.dataset.navigation === 'true') {
        config.navigation = {
          nextEl: el.querySelector('.swiper-button-next'),
          prevEl: el.querySelector('.swiper-button-prev'),
        };
      }
      if (el.dataset.pagination === 'true') {
        config.pagination = {
          el: el.querySelector('.swiper-pagination'),
          clickable: true,
        };
      }

      new Swiper(el, config);
      return true;
    }

    function initAll() {
      document.querySelectorAll('[data-albora-fp]').forEach(initVitrine);
    }

    if (typeof Swiper === 'undefined') {
      // Swiper é carregado com `defer`; espera o load.
      window.addEventListener('load', initAll);
    } else {
      initAll();
    }

    // Reinicializa no editor de temas ao alterar a seção.
    document.addEventListener('shopify:section:load', function (e) {
      e.target.querySelectorAll('[data-albora-fp]').forEach(function (el) {
        el.dataset.inited = 'false';
        initVitrine(el);
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Albora Vitrine",
  "tag": "section",
  "class": "albora-featured-products-section",
  "settings": [
    { "type": "header", "content": "Produtos" },
    { "type": "collection", "id": "collection", "label": "Coleção" },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Produtos exibidos",
      "default": 8
    },
    { "type": "checkbox", "id": "show_description", "label": "Mostrar descrição", "default": true },
    { "type": "checkbox", "id": "show_wishlist", "label": "Mostrar botão de favoritar", "default": true },
    {
      "type": "range",
      "id": "description_words",
      "min": 4,
      "max": 30,
      "step": 1,
      "label": "Palavras na descrição",
      "default": 10,
      "visible_if": "{{ section.settings.show_description }}"
    },

    { "type": "header", "content": "Carrossel" },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Slides visíveis (desktop)",
      "default": 4
    },
    {
      "type": "range",
      "id": "slides_per_view_tablet",
      "min": 1.2,
      "max": 4,
      "step": 0.1,
      "label": "Slides visíveis (tablet)",
      "default": 2.5
    },
    {
      "type": "range",
      "id": "slides_per_view_mobile",
      "min": 1,
      "max": 3,
      "step": 0.1,
      "label": "Slides visíveis (mobile)",
      "default": 1.7
    },
    { "type": "checkbox", "id": "loop", "label": "Loop infinito", "default": false },
    { "type": "checkbox", "id": "show_navigation", "label": "Mostrar navegação (setas)", "default": false },
    { "type": "checkbox", "id": "show_pagination", "label": "Mostrar paginação (bolinhas)", "default": false },
    { "type": "color", "id": "controls_color", "label": "Cor dos controles", "default": "#06262D" },

    { "type": "header", "content": "Layout" },
    {
      "type": "range",
      "id": "container_width",
      "min": 1000,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "label": "Largura máxima do container",
      "default": 1440
    },
    { "type": "color", "id": "section_background", "label": "Fundo da seção", "default": "#FFFFFF" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Espaço acima",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Espaço abaixo",
      "default": 60
    },

    { "type": "header", "content": "Conteúdo" },
    { "type": "text", "id": "title", "label": "Título", "default": "Mais vendidos" },
    { "type": "text", "id": "button_label", "label": "Texto do botão", "default": "Mais produtos" },
    { "type": "url", "id": "button_link", "label": "Link do botão" },

    { "type": "header", "content": "Título — tipografia" },
    {
      "type": "range",
      "id": "title_font_size_desktop",
      "min": 14,
      "max": 64,
      "step": 1,
      "unit": "px",
      "label": "Tamanho (desktop)",
      "default": 24
    },
    {
      "type": "range",
      "id": "title_font_size_mobile",
      "min": 12,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Tamanho (mobile)",
      "default": 20
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Peso da fonte",
      "options": [
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semibold (600)" },
        { "value": "700", "label": "Bold (700)" }
