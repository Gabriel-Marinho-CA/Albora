      "label": "Peso da fonte",
      "options": [
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semibold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "default": "600"
    },
    { "type": "color", "id": "card_title_color", "label": "Cor", "default": "#000000" },

    { "type": "header", "content": "Card — descrição" },
    {
      "type": "range",
