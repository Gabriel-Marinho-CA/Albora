      "options": [
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semibold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "default": "400"
    },
    { "type": "color", "id": "card_description_color", "label": "Cor", "default": "#3A575E" },

    { "type": "header", "content": "Card — preço" },
    {
